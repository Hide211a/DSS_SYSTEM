# Local development (SQLite)
DATABASE_URL="file:./dev.db"
PORT=3001

# Admin DSS credentials — change in production
ADMIN_USER=admin
ADMIN_PASSWORD=admin123
JWT_SECRET=stockwise-diploma-secret-change-in-production

# Comma-separated frontend origins for CORS (required for Vercel + Railway split)
# Example: https://stockwise.vercel.app,https://stockwise-git-main-user.vercel.app
CORS_ORIGIN=

# Optional: force re-seed on deploy (wipes demo data)
# FORCE_DB_SEED=true

# Optional: DSS cache TTL in ms (default 60000)
# DSS_CACHE_TTL_MS=60000
