{
  "name": "backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset --force",
    "db:deploy": "prisma db push --accept-data-loss",
    "use:postgres": "node scripts/use-postgres-schema.mjs",
    "build:prod": "node scripts/use-postgres-schema.mjs && prisma generate && npm run build",
    "start:prod": "node scripts/start-production.mjs",
    "test": "vitest run"
  },
  "dependencies": {
    "@prisma/client": "^6.8.2",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "prisma": "^6.8.2",
    "tsx": "^4.19.4",
    "zod": "^3.25.42"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.2",
    "@types/node": "^22.15.21",
    "@types/supertest": "^6.0.3",
    "supertest": "^7.1.1",
    "typescript": "^5.8.3",
    "vitest": "^3.2.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
